<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="pg-reports-root" content="<%= request.script_name.presence || PgReports::Engine.routes.url_helpers.root_path %>">
  <title><%= t("pg_reports.ui.branding.page_title") %></title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%234f46e5'/%3E%3Crect x='5' y='18' width='5' height='9' rx='1' fill='%23fff'/%3E%3Crect x='13.5' y='12' width='5' height='15' rx='1' fill='%23fff'/%3E%3Crect x='22' y='6' width='5' height='21' rx='1' fill='%23fff'/%3E%3C/svg%3E">
  <% if PgReports.config.load_external_fonts %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <% end %>
  <style>
    :root {
      --bg-primary: #151719;
      --bg-secondary: #1c1f22;
      --bg-tertiary: #232629;
      --bg-card: #1c1f22;
      --border-color: #2e3235;
      --text-primary: #c9cbcd;
      --text-secondary: #888d93;
      --text-muted: #5e6369;
      --accent-purple: #7c8af6;
      --accent-blue: #5c9eed;
      --accent-green: #45a87a;
      --accent-amber: #c89030;
      --accent-rose: #d45d6e;
      --accent-indigo: #7c8af6;
      --gradient-start: #7c8af6;
      --gradient-end: #7c8af6;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: <%= PgReports.config.load_external_fonts ? "'Plus Jakarta Sans', " : "" %>-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.6;
    }

    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 1.5rem;
    }

    /* Header */
    .header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--border-color);
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .logo-icon {
      width: 32px;
      height: 32px;
      background: var(--accent-purple);
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }

    .logo-text {
      display: flex;
      flex-direction: column;
      gap: 5px;
      line-height: 1.15;
    }

    .logo-text h1 {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.15;
      margin-top: -3px;
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }

    .logo-version {
      font-size: 0.7rem;
      font-weight: 500;
      color: var(--text-muted);
      letter-spacing: 0.02em;
    }

    .logo-subtitle {
      font-size: 0.7rem;
      color: var(--text-muted);
      line-height: 1.15;
    }

    .header-badge {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      height: 2.125rem;
      padding: 0 0.75rem;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 4px;
      font-size: 0.75rem;
    }

    .header-badge-clickable {
      cursor: pointer;
      font-family: inherit;
      color: inherit;
      transition: border-color 0.15s ease, background 0.15s ease;
    }

    .header-badge-clickable:hover {
      background: var(--bg-card);
      border-color: var(--text-muted);
    }

    .badge-info-icon {
      color: var(--text-muted);
      font-size: 0.85rem;
      line-height: 1;
    }

    .badge-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent-green);
      animation: pulse 2s infinite;
    }

    .badge-dot.warning {
      background: var(--accent-amber);
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }

    /* Categories Grid */
    .categories-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .category-card {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 1rem;
    }

    .category-card:hover {
      border-color: #3e4347;
    }

    .category-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.875rem;
    }

    .category-icon {
      width: 28px;
      height: 28px;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.95rem;
      background: transparent !important;
      color: var(--text-secondary) !important;
    }

    .category-title {
      font-size: 1rem;
      font-weight: 600;
    }

    .category-count {
      margin-left: auto;
      padding: 0.2rem 0.6rem;
      background: var(--bg-tertiary);
      border-radius: 4px;
      font-size: 0.7rem;
      color: var(--text-muted);
    }

    .reports-list {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    .report-link {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.45rem 0.7rem;
      background: transparent;
      border: 1px solid transparent;
      border-radius: 4px;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.82rem;
      transition: background 0.1s, color 0.1s;
    }

    .report-link:hover {
      background: var(--bg-tertiary);
      color: var(--text-primary);
    }

    .report-link .arrow {
      opacity: 0;
      transform: translateX(-4px);
      transition: all 0.15s ease;
    }

    .report-link:hover .arrow {
      opacity: 1;
      transform: translateX(0);
    }

    .report-badge-new {
      display: inline-block;
      margin-left: 0.4rem;
      padding: 0.1rem 0.35rem;
      font-size: 0.55rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      line-height: 1.2;
      color: var(--accent-green);
      background: rgba(69, 168, 122, 0.12);
      border-radius: 3px;
      vertical-align: middle;
    }

    /* Report Detail Page */
    .report-page {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .breadcrumb a {
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.15s;
    }

    .breadcrumb a:hover {
      color: var(--text-primary);
    }

    .report-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1.5rem;
    }

    .report-info h2 {
      font-size: 1.4rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
    }

    .report-info p {
      color: var(--text-muted);
      font-size: 0.875rem;
    }

    .report-actions {
      display: flex;
      gap: 0.5rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      height: 36px;
      padding: 0 1rem;
      border: 1px solid transparent;
      border-radius: 4px;
      font-family: inherit;
      font-size: 0.8rem;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.1s;
      white-space: nowrap;
      text-decoration: none;
    }

    .btn-primary {
      background: var(--accent-purple);
      color: #fff;
      border-color: var(--accent-purple);
    }

    .btn-primary:hover {
      background: #6b79e4;
    }

    .btn-secondary {
      background: var(--bg-tertiary);
      color: var(--text-secondary);
      border: 1px solid var(--border-color);
    }

    .btn-secondary:hover {
      background: #2a2d31;
      color: var(--text-primary);
    }

    .btn-telegram {
      background: var(--bg-tertiary);
      color: var(--text-secondary);
      border: 1px solid var(--border-color);
    }

    .btn-telegram:hover {
      background: #2a2d31;
      color: var(--text-primary);
    }

    .btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Results Table */
    .results-container {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      overflow: hidden;
    }

    .results-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.875rem 1rem;
      border-bottom: 1px solid var(--border-color);
    }

    .results-title {
      font-weight: 600;
      font-size: 0.9rem;
    }

    .results-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      color: var(--text-muted);
      font-size: 0.75rem;
    }

    .results-table-wrapper {
      overflow-x: auto;
    }

    .results-table {
      width: 100%;
      border-collapse: collapse;
      font-family: <%= PgReports.config.load_external_fonts ? "'JetBrains Mono', " : "" %>SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size: 0.75rem;
    }

    .results-table th {
      padding: 0.7rem 0.875rem;
      text-align: left;
      background: var(--bg-tertiary);
      color: var(--text-muted);
      font-weight: 500;
      text-transform: uppercase;
      font-size: 0.65rem;
      letter-spacing: 0.05em;
      white-space: nowrap;
      border-bottom: 1px solid var(--border-color);
    }

    .results-table td {
      padding: 0.65rem 0.875rem;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-secondary);
      max-width: 400px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .results-table tr:hover td {
      background: var(--bg-tertiary);
      color: var(--text-primary);
    }

    .results-table td.query-cell {
      max-width: 500px;
      font-size: 0.75rem;
    }

    .empty-state {
      padding: 3rem 1.5rem;
      text-align: center;
      color: var(--text-muted);
      font-size: 0.85rem;
    }

    .empty-state-icon {
      font-size: 2.5rem;
      margin-bottom: 0.75rem;
    }

    .loading {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 3rem 1.5rem;
    }

    .spinner {
      width: 36px;
      height: 36px;
      border: 3px solid var(--border-color);
      border-top-color: var(--accent-purple);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* Error state */
    .error-message {
      padding: 0.875rem;
      background: rgba(244, 63, 94, 0.1);
      border: 1px solid rgba(244, 63, 94, 0.3);
      border-radius: 6px;
      color: var(--accent-rose);
      font-size: 0.85rem;
    }

    /* Toast notification */
    .toast {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      padding: 0.75rem 1rem;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      color: var(--text-primary);
      font-size: 0.85rem;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      transform: translateY(100px);
      opacity: 0;
      transition: all 0.3s ease;
      z-index: 1000;
    }

    .toast.show {
      transform: translateY(0);
      opacity: 1;
    }

    .toast.success {
      border-color: var(--accent-green);
    }

    .toast.error {
      border-color: var(--accent-rose);
    }

    /* Modal */
    .modal {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.6);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }

    .modal-content {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      max-width: 900px;
      width: 90%;
      max-height: 90vh;
      overflow: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--border-color) var(--bg-secondary);
    }

    .modal-content::-webkit-scrollbar,
    .modal-body::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    .modal-content::-webkit-scrollbar-track,
    .modal-body::-webkit-scrollbar-track {
      background: var(--bg-secondary);
      border-radius: 4px;
    }

    .modal-content::-webkit-scrollbar-thumb,
    .modal-body::-webkit-scrollbar-thumb {
      background: var(--border-color);
      border-radius: 4px;
    }

    .modal-content::-webkit-scrollbar-thumb:hover,
    .modal-body::-webkit-scrollbar-thumb:hover {
      background: var(--text-muted);
    }

    .modal-content::-webkit-scrollbar-corner,
    .modal-body::-webkit-scrollbar-corner {
      background: var(--bg-secondary);
    }

    .modal-large {
      max-width: 900px;
      width: 95%;
    }

    .modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.875rem 1rem;
      border-bottom: 1px solid var(--border-color);
    }

    .modal-header h3 {
      font-size: 1rem;
      font-weight: 600;
    }

    .modal-close {
      width: 28px;
      height: 28px;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 4px;
      color: var(--text-muted);
      font-size: 1.125rem;
      cursor: pointer;
      transition: all 0.15s;
    }

    .modal-close:hover {
      background: var(--accent-rose);
      border-color: var(--accent-rose);
      color: white;
    }

    .modal-body {
      padding: 1rem;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .container {
        padding: 0.875rem;
      }

      .header {
        flex-direction: column;
        gap: 0.75rem;
        align-items: flex-start;
      }

      .report-header {
        flex-direction: column;
      }

      .report-actions {
        width: 100%;
      }

      .btn {
        flex: 1;
        justify-content: center;
      }
    }

    /* ============================================
       Query Monitoring Panel
       ============================================ */
    .query-monitoring-panel {
      margin-bottom: 1.5rem;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 0.875rem 1rem;
    }

    .query-monitoring-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.875rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--border-color);
    }

    .query-monitoring-title {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-weight: 600;
      font-size: 0.9rem;
    }

    .query-monitoring-scope {
      position: relative;
      font-weight: 400;
      font-size: 0.75rem;
      color: var(--text-muted);
      background: var(--bg-tertiary);
      padding: 0.125rem 0.5rem;
      border-radius: 999px;
      cursor: help;
    }

    .query-monitoring-scope::after {
      content: attr(data-tooltip);
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      z-index: 100;
      width: max-content;
      max-width: 320px;
      padding: 0.6rem 0.75rem;
      background: var(--bg-card);
      color: var(--text-secondary);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      box-shadow: 0 6px 18px rgba(0, 0, 0, 0.35);
      font-size: 0.75rem;
      font-weight: 400;
      line-height: 1.5;
      white-space: normal;
      text-align: left;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-4px);
      transition: opacity 0.15s ease, transform 0.15s ease;
      pointer-events: none;
    }

    .query-monitoring-scope:hover::after,
    .query-monitoring-scope:focus::after,
    .query-monitoring-scope:focus-visible::after {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .monitoring-indicator {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--text-muted);
    }

    .monitoring-indicator.active {
      background: var(--accent-rose);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% {
        opacity: 1;
      }
      50% {
        opacity: 0.5;
      }
    }

    .session-badge {
      margin-left: 0.4rem;
      padding: 0.3rem 0.6rem;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 4px;
      font-size: 0.65rem;
      font-weight: 500;
      color: var(--text-secondary);
    }

    .session-badge strong {
      color: var(--accent-purple);
      font-family: <%= PgReports.config.load_external_fonts ? "'JetBrains Mono', " : "" %>monospace;
    }

    .query-monitoring-controls {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .query-monitoring-count {
      font-size: 0.75rem;
      color: var(--text-secondary);
    }

    .query-monitoring-count strong {
      color: var(--accent-blue);
      font-weight: 600;
    }

    /* Query Feed */
    .query-feed {
      max-height: 500px;
      overflow-y: auto;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 0.75rem;
    }

    .query-feed::-webkit-scrollbar {
      width: 6px;
    }

    .query-feed::-webkit-scrollbar-track {
      background: var(--bg-secondary);
      border-radius: 3px;
    }

    .query-feed::-webkit-scrollbar-thumb {
      background: var(--border-color);
      border-radius: 3px;
    }

    .query-feed::-webkit-scrollbar-thumb:hover {
      background: var(--text-muted);
    }

    .query-feed-empty {
      text-align: center;
      padding: 2rem;
      color: var(--text-muted);
      font-size: 0.8rem;
    }

    .query-item {
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 0.5rem;
      margin-bottom: 0.5rem;
      font-size: 0.8rem;
      transition: all 0.15s;
    }

    .query-item:hover {
      border-color: var(--accent-purple);
    }

    .query-item:last-child {
      margin-bottom: 0;
    }

    .query-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.3rem;
    }

    .query-meta {
      display: flex;
      gap: 0.6rem;
      font-size: 0.7rem;
      color: var(--text-muted);
    }

    .query-timestamp {
      color: var(--text-secondary);
      font-size: 0.7rem;
    }

    .query-duration {
      color: var(--accent-amber);
      font-weight: 600;
      font-size: 0.7rem;
    }

    .query-duration.fast {
      color: var(--accent-green);
    }

    .query-duration.slow {
      color: var(--accent-rose);
    }

    .query-name {
      color: var(--text-secondary);
      font-style: italic;
      font-size: 0.7rem;
    }

    .query-expand-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      padding: 0.15rem 0.35rem;
      font-size: 0.7rem;
      transition: all 0.15s;
      border-radius: 3px;
    }

    .query-expand-btn:hover {
      background: var(--bg-tertiary);
      color: var(--accent-purple);
    }

    .query-sql-wrapper {
      margin-bottom: 0.3rem;
    }

    .query-sql {
      padding: 0.5rem;
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 4px;
      font-family: <%= PgReports.config.load_external_fonts ? "'JetBrains Mono', " : "" %>monospace;
      font-size: 0.7rem;
      color: var(--accent-blue);
      word-wrap: break-word;
      overflow-x: auto;
    }

    .query-sql-collapsed {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .query-sql-expanded {
      white-space: pre-wrap;
    }

    .query-source {
      font-size: 0.7rem;
      color: var(--text-muted);
      font-family: <%= PgReports.config.load_external_fonts ? "'JetBrains Mono', " : "" %>monospace;
    }

    .query-source a {
      color: var(--accent-purple);
      text-decoration: none;
    }

    .query-source a:hover {
      text-decoration: underline;
    }

    /* IDE Dropdown for query source links */
    .ide-dropdown-overlay {
      position: fixed;
      inset: 0;
      z-index: 999;
      display: none;
    }

    .ide-dropdown-overlay.show {
      display: block;
    }

    .ide-menu {
      position: fixed;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      z-index: 1000;
      min-width: 160px;
      overflow: hidden;
      display: none;
    }

    .ide-menu.show {
      display: block;
    }

    .ide-menu a {
      display: block;
      padding: 0.6rem 0.875rem;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.75rem;
      transition: all 0.15s ease;
      border-bottom: 1px solid var(--border-color);
    }

    .ide-menu a:last-child {
      border-bottom: none;
    }

    .ide-menu a:hover {
      background: var(--bg-tertiary);
      color: var(--text-primary);
    }

    /* Download Dropdown */
    .download-dropdown {
      position: relative;
      display: inline-block;
    }

    .download-menu {
      position: absolute;
      top: calc(100% + 0.4rem);
      right: 0;
      min-width: 160px;
      background: var(--bg-card);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
      z-index: 100;
      overflow: hidden;
    }

    .download-menu a {
      display: block;
      padding: 0.6rem 0.875rem;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 0.75rem;
      transition: all 0.15s ease;
      border-bottom: 1px solid var(--border-color);
    }

    .download-menu a:last-child {
      border-bottom: none;
    }

    .download-menu a:hover {
      background: var(--bg-tertiary);
      color: var(--text-primary);
    }

    .btn-small {
      height: 30px;
      padding: 0 0.875rem;
      font-size: 0.75rem;
      line-height: 1;
    }

    .btn-danger {
      background: var(--accent-rose);
      color: white;
      border-color: var(--accent-rose);
    }

    .btn-danger:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    /* IDE Settings Modal */
    .settings-label {
      color: var(--text-secondary);
      margin-bottom: 1rem;
      font-size: 0.9rem;
    }

    .ide-options {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .ide-option {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.75rem 1rem;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.15s;
    }

    .ide-option:hover {
      background: var(--bg-secondary);
      border-color: var(--accent-purple);
    }

    .ide-option:has(input:checked) {
      background: rgba(157, 140, 214, 0.15);
      border-color: var(--accent-purple);
    }

    .ide-option input[type="radio"] {
      accent-color: var(--accent-purple);
    }

    .ide-option span {
      color: var(--text-secondary);
      font-size: 0.875rem;
    }

    .ide-option:has(input:checked) span {
      color: var(--text-primary);
    }

    .modal-small {
      max-width: 360px;
    }

    .modal-medium {
      max-width: 560px;
    }

    /* Database selector — used inside .live-monitoring-title and .breadcrumb.
       Sizes to fit its longest option (no artificial cap), capped at the
       parent's available width so it never overruns neighboring controls. */
    .db-selector-form {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin: 0;
      max-width: 100%;
      min-width: 0;
    }

    .db-selector-label {
      font-size: 0.75rem;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 600;
      white-space: nowrap;
    }

    .db-selector {
      background: var(--bg-card, rgba(255, 255, 255, 0.04));
      color: var(--text-primary);
      border: 1px solid var(--border-color, rgba(255, 255, 255, 0.1));
      border-radius: 6px;
      padding: 0.375rem 0.625rem;
      font-size: 0.875rem;
      cursor: pointer;
      width: auto;
      max-width: 100%;
      min-width: 0;
    }

    .db-selector option.is-default {
      font-weight: 700;
    }

    .db-selector:hover {
      border-color: var(--accent-blue, #6b9fe8);
    }

    .db-selector:focus {
      outline: none;
      border-color: var(--accent-blue, #6b9fe8);
      box-shadow: 0 0 0 2px rgba(107, 159, 232, 0.2);
    }

    .db-selector-static {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .db-selector-static strong {
      color: var(--text-primary);
    }

    .db-selector-error {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      padding: 0.375rem 0.625rem;
      background: rgba(232, 107, 107, 0.1);
      border: 1px solid rgba(232, 107, 107, 0.3);
      border-radius: 6px;
      font-size: 0.8125rem;
      color: var(--accent-red, #e86b6b);
      cursor: help;
    }

    .breadcrumb-spacer {
      flex: 1;
    }

    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .db-error-banner {
      background: rgba(232, 107, 107, 0.08);
      border: 1px solid rgba(232, 107, 107, 0.3);
      border-radius: 8px;
      padding: 0.875rem 1.125rem;
      margin-bottom: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    .db-error-banner strong {
      color: var(--accent-red, #e86b6b);
      font-size: 0.9375rem;
    }

    .db-error-banner span {
      font-size: 0.875rem;
      color: var(--text-secondary);
    }

    .db-error-banner code {
      font-family: ui-monospace, SFMono-Regular, monospace;
      font-size: 0.8125rem;
      background: rgba(0, 0, 0, 0.25);
      padding: 0.375rem 0.625rem;
      border-radius: 4px;
      color: var(--text-primary);
      display: inline-block;
      width: fit-content;
    }
  </style>
</head>
<body>
  <div class="container">
    <%= yield %>
  </div>

  <div id="toast" class="toast"></div>

  <!-- IDE Dropdown overlay and menu -->
  <div id="ide-dropdown-overlay" class="ide-dropdown-overlay" onclick="closeIdeMenu()"></div>
  <div id="ide-menu" class="ide-menu"></div>

  <script>
    const pgReportsRoot = document.querySelector('meta[name="pg-reports-root"]')?.content || '/pg_reports';
    window.PG_REPORTS_I18N = <%= raw I18n.t("pg_reports.ui").to_json %>;

    // Format strings with %{var} placeholders
    window.pgReportsFormat = function(template, vars) {
      if (!template) return '';
      return template.replace(/%\{(\w+)\}/g, function(_, k) { return vars[k] != null ? vars[k] : ''; });
    };

    // Close the topmost open modal on ESC. Applies to every `.modal` that has a
    // close (×) button — it triggers that button so each modal's own close
    // handler (and any cleanup) runs.
    document.addEventListener('keydown', function(e) {
      if (e.key !== 'Escape' && e.key !== 'Esc') return;
      const open = Array.prototype.slice.call(document.querySelectorAll('.modal'))
        .filter(function(m) {
          return getComputedStyle(m).display !== 'none' && m.querySelector('.modal-close');
        });
      if (!open.length) return;
      e.preventDefault();
      const modal = open[open.length - 1];
      const closeBtn = modal.querySelector('.modal-close');
      if (closeBtn) {
        closeBtn.click();
      } else {
        modal.style.display = 'none';
      }
    });

    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      toast.textContent = message;
      toast.className = 'toast show ' + type;
      setTimeout(() => {
        toast.className = 'toast';
      }, 3000);
    }

    async function sendToTelegram(category, report, button) {
      if (button) {
        button.disabled = true;
        button.innerHTML = '<span class="spinner" style="width:16px;height:16px;border-width:2px;display:inline-block;vertical-align:middle;"></span> ' + PG_REPORTS_I18N.actions.sending;
      }

      try {
        const response = await fetch(`${pgReportsRoot}/${category}/${report}/telegram`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
          }
        });

        const data = await response.json();

        if (data.success) {
          showToast(PG_REPORTS_I18N.success.telegram_sent);
        } else {
          showToast(data.error || PG_REPORTS_I18N.errors.send_telegram_failed, 'error');
        }
      } catch (error) {
        showToast(PG_REPORTS_I18N.errors.network_error_prefix + ' ' + error.message, 'error');
      }

      if (button) {
        button.disabled = false;
        button.innerHTML = PG_REPORTS_I18N.actions.send_telegram;
      }
    }
  </script>
</body>
</html>
